# 私密授權金鑰絕不可上傳
*.pem
private_key.*
*-firebase-adminsdk-*.json
service-account*.json
.env
.env.*
!.env.example

# 套件、Firebase 暫存與正式發布成品
node_modules/
dist/
.firebase/
firebase-debug.log*
*.map

# 作業系統與編輯器暫存檔
.DS_Store
Thumbs.db
*.tmp
*.bak

# Android 簽章金鑰:遺失或外洩都無法挽回,絕不可進版控
*.keystore
*.jks
*.pepk
android-signing*
signing-key*

# 官方原始快取:132MB,可由 scripts/fetch-pesticide-source.mjs 重新產生
mrl-data/source-cache/
