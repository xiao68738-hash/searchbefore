rules_version = '2';

/* 噴前查雲端同步安全規則

   原則:每個人只能讀寫自己的資料,沒有任何跨帳號存取途徑。
   田間紀錄含農友的作物、田區與用藥細節,外洩等同洩漏經營資訊。

   部署方式(擇一):
     firebase deploy --only firestore:rules
   或在 Firebase Console → Firestore Database → 規則 貼上後發布。

   ⚠️ 建立 Firestore 時若選「測試模式」,預設規則是「任何人都可讀寫」,
      且 30 天後全部拒絕。務必在上線前用這份規則覆蓋掉。 */

service cloud.firestore {
  match /databases/{database}/documents {

    /* users/{uid}/records|fieldPlots|farmRecords/{docId} */
    match /users/{userId}/{collection}/{docId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId
                         && collection in ["records", "fieldPlots", "farmRecords"];
    }

    /* 其餘一律拒絕。不寫這條的話,未來新增的路徑會沿用預設,容易漏。 */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
